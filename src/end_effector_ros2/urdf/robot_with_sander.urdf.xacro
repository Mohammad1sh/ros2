<?xml version="1.0"?>
<!--
  robot_with_sander.urdf.xacro
  ============================
  Doosan H2515 + zımpara end-effector (Gazebo/Ignition simülasyonu için).

  Tasarım notları:
  - simple:=true ile doosan xacro'sundan SADECE link/joint'ler alınır.
    (world linki, ros2_control ve gazebo plugin'i doosan tarafında EKLENMEZ —
     böylece çift controller_manager çakışması olmaz. Hepsi burada tek elden.)
  - "zimpara_ucu_v52.dae" komple end-effector CAD montajıdır (zımpara tutucular +
    kamera kutusu + flanşlar) ve METRE cinsindendir → scale 1 1 1.
    Montaj koordinatında flanş plakasının üst yüzü z=0.157'dedir; rpy=[pi,0,0] ile
    çevrilip link_6 flanşına oturtulur (montaj gövdesi link_6'nın +Z'sine uzanır).
  - Dönen zımpara diski ayrı bir link'tir (sander_tip_link) — basit silindir görseli,
    zimpara_velocity_controller ile döndürülür.
  - servo_joint: kamera kutusu kapağı (prismatik, 0–0.025 m) — gazebo_bridge'in
    gönderdiği 7. eksen komutuyla uyumludur.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="doosan_with_sander">

  <!-- Bu arg'lar include'dan ÖNCE tanımlanmalı (ilk tanım kazanır) -->
  <xacro:arg name="color"     default="white"/>
  <xacro:arg name="namespace" default=""/>
  <xacro:arg name="simple"    default="true"/>
  <!-- true = 17MB CAD montajı (yavaş), false = hafif basit geometri (hızlı) -->
  <xacro:arg name="detailed_sander" default="true"/>

  <xacro:include filename="$(find dsr_description2)/xacro/h2515.urdf.xacro" />

  <!-- ── Dünyaya sabitle ──────────────────────────────────────────────── -->
  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- ── Kol eklemleri (joint_1..6) için Ignition ros2_control ────────── -->
  <xacro:include filename="$(find dsr_description2)/ros2_control/h2515.gz_ros2_control.xacro"/>
  <xacro:h2515_gz_ros2_control namespace="" update_rate="100"/>

  <!-- ── Zımpara end-effector montajı (komple CAD) ─────────────────────── -->
  <link name="sander_base_link">
    <xacro:if value="$(arg detailed_sander)">
      <visual>
        <origin xyz="0 0 0.157" rpy="${pi} 0 0"/>
        <geometry>
          <mesh filename="package://end_effector_ros2/meshes/zimpara_ucu_v52.dae" scale="1 1 1"/>
        </geometry>
      </visual>
    </xacro:if>
    <xacro:unless value="$(arg detailed_sander)">
      <!-- Hafif temsil: montaj plakası + zımpara gövdesi + kamera kutusu -->
      <visual>
        <origin xyz="0.003 -0.055 0.035" rpy="0 0 0"/>
        <geometry><box size="0.16 0.30 0.03"/></geometry>
        <material name="sander_mount_grey"><color rgba="0.45 0.45 0.50 1.0"/></material>
      </visual>
      <visual>
        <origin xyz="0.003 0.011 0.13" rpy="0 0 0"/>
        <geometry><cylinder radius="0.05" length="0.16"/></geometry>
        <material name="sander_body_dark"><color rgba="0.20 0.20 0.22 1.0"/></material>
      </visual>
      <visual>
        <origin xyz="0.003 -0.144 0.13" rpy="0 0 0"/>
        <geometry><box size="0.09 0.09 0.14"/></geometry>
        <material name="cam_box_grey"><color rgba="0.35 0.38 0.42 1.0"/></material>
      </visual>
    </xacro:unless>
    <!-- Çarpışma için basit kutu (17MB mesh'i collision yapmak performansı öldürür) -->
    <collision>
      <origin xyz="0.003 -0.055 0.105" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <origin xyz="0.0 -0.05 0.10" rpy="0 0 0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="sander_attachment_joint" type="fixed">
    <parent link="link_6"/>
    <child link="sander_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── Dönen zımpara diski ───────────────────────────────────────────── -->
  <link name="sander_tip_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.02"/>
      </geometry>
      <material name="sander_pad_red">
        <color rgba="0.75 0.12 0.10 1.0"/>
      </material>
    </visual>
    <!-- Dönüşün gözle görülmesi için disk kenarında işaret -->
    <visual>
      <origin xyz="0.030 0 0.011" rpy="0 0 0"/>
      <geometry>
        <box size="0.022 0.008 0.004"/>
      </geometry>
      <material name="sander_mark_black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.001" length="0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- Montajın zımpara ünitesi ekseni link_6 çerçevesinde (0.003, 0.011);
       montaj alt yüzü z≈0.207 → disk merkezi z=0.215 (temas yüzü ≈0.225) -->
  <joint name="sander_spin_joint" type="continuous">
    <parent link="sander_base_link"/>
    <child link="sander_tip_link"/>
    <origin xyz="0.003 0.011 0.215" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01"/>
  </joint>

  <!-- ── Kamera kutusu kapağı (servo_joint — 7. eksen) ─────────────────── -->
  <link name="camera_lid_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.008"/>
      </geometry>
      <material name="cam_lid_grey">
        <color rgba="0.30 0.30 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.008"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- Kamera ünitesi link_6 çerçevesinde (0.003, -0.144) tarafındadır -->
  <joint name="servo_joint" type="prismatic">
    <parent link="sander_base_link"/>
    <child link="camera_lid_link"/>
    <origin xyz="0.003 -0.144 0.213" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.025" effort="50" velocity="0.1"/>
  </joint>

  <!-- ── Zımpara + servo için ros2_control donanımı ────────────────────── -->
  <ros2_control name="SanderGazeboHardware" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin>
    </hardware>
    <joint name="sander_spin_joint">
      <command_interface name="velocity">
        <param name="min">-200</param>
        <param name="max">200</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="servo_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.025</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ── TEK ros2_control plugin'i — /gz namespace'inde ────────────────── -->
  <gazebo>
    <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <ros>
        <namespace>gz</namespace>
      </ros>
      <!-- Plugin robot_description'ı /gz/robot_state_publisher parametre
           servisinden okur (rsp launch'ta gz namespace'inde başlatılır) -->
      <parameters>$(find end_effector_ros2)/config/sander_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
